# traider — environment file template. Copy to .env and fill in.
# See README.md § "Choosing a market-data backend" for the full story.

# Which docker compose services to start. Comma-separated.
#
# Exactly one market-data backend (schwab / yahoo — they share port 8765):
#   schwab  → needs SCHWAB_APP_KEY / SCHWAB_APP_SECRET below, plus
#             a one-time `schwab-connector auth` browser flow.
#   yahoo   → no account, no auth; uses yfinance's unofficial endpoints.
#
# Any mix of additive servers (each on its own port):
#   fred          → macro / economic-release calendar via FRED (needs FRED_API_KEY).
#   fed-calendar  → FOMC meeting dates scraped from federalreserve.gov (no creds).
#   sec-edgar     → SEC EDGAR filings / Form 4 / 13F / XBRL (needs SEC_EDGAR_USER_AGENT).
#   factor        → Ken French Data Library: Fama-French factors, momentum,
#                   industry portfolios. No creds. Disk-cached on the host at
#                   ~/.cache/traider-factor-connector/ (24 h TTL).
#   treasury      → US Treasury Fiscal Data: auction results, Daily Treasury
#                   Statement (TGA), debt-to-the-penny. No creds. (Yield-curve
#                   queries route to fred, not here.)
#   news          → Massive news API: ticker-scoped headlines with sentiment
#                   insights (needs MASSIVE_API_KEY).
#
# Example (Yahoo quotes + FRED macro + FOMC calendar + EDGAR fundamentals + factors + Treasury):
#   COMPOSE_PROFILES=yahoo,fred,fed-calendar,sec-edgar,factor,treasury
COMPOSE_PROFILES=schwab

# Schwab developer-app credentials. Only used when COMPOSE_PROFILES includes schwab.
# Leave these as-is if you're running the Yahoo backend.
SCHWAB_APP_KEY=...
SCHWAB_APP_SECRET=...
SCHWAB_CALLBACK_URL=https://127.0.0.1

# FRED API key — free, from https://fredaccount.stlouisfed.org/apikeys.
# Only used when COMPOSE_PROFILES includes fred.
FRED_API_KEY=...

# SEC Fair Access User-Agent. SEC requires every EDGAR request to
# identify the client and include a contact email, or they will
# IP-block. Use your own name/email — do NOT copy a sample string.
# Only used when COMPOSE_PROFILES includes sec-edgar.
SEC_EDGAR_USER_AGENT=traider-hub you@example.com

# factor-connector has no credentials. The Docker image mounts
# ~/.cache/traider-factor-connector/ from the host as its cache
# directory so ZIPs persist across container restarts. To relocate
# the host path, edit docker-compose.yml at the repo root (host-mode runs
# respect FACTOR_CACHE_DIR below).
# FACTOR_CACHE_DIR=/custom/cache/path

# treasury-connector has no credentials. Fiscal Data
# (api.fiscaldata.treasury.gov) is unauthenticated. Only used when
# COMPOSE_PROFILES includes treasury.

# Massive news API key — register at https://massive.com. Free tier
# available; rate limits apply. Only used when COMPOSE_PROFILES
# includes news.
MASSIVE_API_KEY=...
