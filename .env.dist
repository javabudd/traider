# traider — environment file template. Copy to .env and fill in.
# See README.md for details.

# Which providers the unified traider server should load at startup.
# Comma-separated provider names.
#
# Exactly one market-data backend (schwab / yahoo — they expose the
# same tool names and are mutually exclusive):
#   schwab  → needs SCHWAB_APP_KEY / SCHWAB_APP_SECRET below, plus
#             a one-time `traider auth schwab` browser flow.
#   yahoo   → no account, no auth; uses yfinance's unofficial endpoints.
#
# Any mix of additive providers:
#   fred          → macro / economic-release calendar (needs FRED_API_KEY).
#   fed-calendar  → FOMC meeting dates scraped from federalreserve.gov.
#   sec-edgar     → SEC EDGAR filings / Form 4 / 13F / XBRL (needs SEC_EDGAR_USER_AGENT).
#   factor        → Ken French Data Library (no creds). Disk-cached on the host at
#                   ~/.cache/traider-factor/ (24 h TTL).
#   treasury      → US Treasury Fiscal Data (no creds). Yield-curve
#                   queries route to fred, not here.
#   news          → Massive news API (needs MASSIVE_API_KEY).
#   earnings      → Finnhub earnings calendar + surprises (needs FINNHUB_API_KEY).
#   estimates     → Finnhub analyst recommendation trends — shares FINNHUB_API_KEY
#                   with earnings. Free tier is recommendation trends only;
#                   price targets / upgrades / EPS estimates are premium-only.
#   eia           → US Energy Information Administration: weekly petroleum
#                   stocks, natural gas storage, monthly electricity
#                   generation (needs EIA_API_KEY).
#   cftc          → CFTC Commitments of Traders weekly futures positioning
#                   (no creds; optional CFTC_APP_TOKEN raises rate limits).
#
# The `intent` provider (local trade-intent journal + framework rules
# surface) is core analyst infrastructure and is *always loaded*
# regardless of this list. No need to add it; listing it explicitly
# is harmless but redundant.
#
# Default: every provider that needs no API key — Yahoo market data,
# FOMC calendar, Ken French factors, Treasury, and CFTC positioning.
# Add API-key providers (fred, sec-edgar, news, earnings, estimates,
# eia) as you obtain credentials, or swap `yahoo` for `schwab` once
# you've completed the OAuth flow.
TRAIDER_PROVIDERS=yahoo,fed-calendar,factor,treasury,cftc

# Schwab developer-app credentials. Only used when TRAIDER_PROVIDERS includes schwab.
SCHWAB_APP_KEY=...
SCHWAB_APP_SECRET=...
SCHWAB_CALLBACK_URL=https://127.0.0.1

# FRED API key — free, from https://fredaccount.stlouisfed.org/apikeys.
# Only used when TRAIDER_PROVIDERS includes fred.
FRED_API_KEY=...

# SEC Fair Access User-Agent. SEC requires every EDGAR request to
# identify the client and include a contact email, or they will
# IP-block. Use your own name/email — do NOT copy a sample string.
# Only used when TRAIDER_PROVIDERS includes sec-edgar.
SEC_EDGAR_USER_AGENT=traider-hub you@example.com

# factor provider has no credentials. The Docker image mounts
# ~/.cache/traider-factor/ from the host as its cache directory so
# ZIPs persist across container restarts. Override the in-container
# path with FACTOR_CACHE_DIR.
# FACTOR_CACHE_DIR=/custom/cache/path

# treasury provider has no credentials. Fiscal Data
# (api.fiscaldata.treasury.gov) is unauthenticated.

# Massive news API key — register at https://massive.com. Free tier
# available; rate limits apply. Only used when TRAIDER_PROVIDERS
# includes news.
MASSIVE_API_KEY=...

# Finnhub API key — register at https://finnhub.io. Free tier covers
# US earnings calendar + historical surprises and analyst recommendation
# trends at a shared 60 req/min budget. Used when TRAIDER_PROVIDERS
# includes earnings and/or estimates (one key, both providers).
FINNHUB_API_KEY=...

# EIA API key — free, from https://www.eia.gov/opendata/register.php.
# Only used when TRAIDER_PROVIDERS includes eia. Quota is 5000
# requests per hour per key.
EIA_API_KEY=...

# cftc provider has no credentials — the Socrata public-reporting
# endpoint at publicreporting.cftc.gov is open. An optional app token
# raises the per-IP rate limit; register at
# https://evergreen.data.socrata.com/signup if you hit throttles.
# CFTC_APP_TOKEN=...

# intent provider (always loaded) reads/writes user data under
# ~/.traider/ by default — intents journal (intents.db), account
# profile (account-profiles.yaml), per-user rule overrides
# (rules.local/). In docker, the whole directory is mounted into the
# container as a single bind, so overriding the *host* root with
# TRAIDER_HOME relocates all three at once (e.g. an encrypted volume
# or a synced folder you control).
# TRAIDER_HOME=/path/to/traider-data
#
# Per-file overrides still work for non-docker runs, or for pointing
# a single file outside ~/.traider/ — note the docker mount won't
# follow these, so if you point one outside ~/.traider/ in a
# containerized setup you'll need an additional bind mount.
# TRAIDER_INTENT_DB=/path/to/intents.db
# TRAIDER_ACCOUNT_PROFILES=/path/to/account-profiles.yaml

# Framework rules. Seed lives at <repo>/rules/ (committed). Per-user
# overrides at <repo>/rules.local/ (gitignored, deep-merged on top of
# the seed). Override either path if your layout differs from the
# repo defaults — e.g. when the server runs in a container with the
# repo mounted at a non-default location.
# TRAIDER_RULES_DIR=/path/to/rules
# TRAIDER_RULES_LOCAL_DIR=/path/to/rules.local
